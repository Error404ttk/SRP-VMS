<section class="mx-auto max-w-7xl space-y-5">
  <div class="flex flex-col justify-between gap-3 sm:flex-row sm:items-center">
    <div>
      <p class="text-sm font-semibold text-sky-600">จัดการรถราชการ</p>
      <h2 class="mt-1 text-2xl font-bold text-slate-950">ข้อมูลรถราชการ</h2>
    </div>
    <button onclick="openVehicleModal()" class="rounded-xl bg-sky-600 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-sky-100 hover:bg-sky-700">
      + เพิ่มรถ
    </button>
  </div>

  <div class="page-card p-4">
    <input
      id="vehicleSearch"
      type="text"
      oninput="renderVehicleTable()"
      class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 outline-none focus:border-sky-400 focus:bg-white focus:ring-4 focus:ring-sky-100"
      placeholder="ค้นหาทะเบียนรถ ชื่อรถ ประเภทรถ หรือสถานะ">
  </div>

  <div class="page-card overflow-hidden">
    <div id="vehicleLoadInfo" class="border-b border-slate-100 px-4 py-3 text-sm text-slate-500">กำลังโหลดข้อมูลรถราชการ...</div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-bold uppercase text-slate-500">ทะเบียนรถ</th>
            <th class="px-4 py-3 text-left text-xs font-bold uppercase text-slate-500">ชื่อรถ</th>
            <th class="px-4 py-3 text-left text-xs font-bold uppercase text-slate-500">ประเภทรถ</th>
            <th class="px-4 py-3 text-left text-xs font-bold uppercase text-slate-500">ยี่ห้อ/รุ่น</th>
            <th class="px-4 py-3 text-right text-xs font-bold uppercase text-slate-500">เลขไมล์</th>
            <th class="px-4 py-3 text-left text-xs font-bold uppercase text-slate-500">สถานะ</th>
            <th class="px-4 py-3 text-right text-xs font-bold uppercase text-slate-500">จัดการ</th>
          </tr>
        </thead>
        <tbody id="vehicleTableBody" class="divide-y divide-slate-100 bg-white"></tbody>
      </table>
    </div>
    <div id="vehicleEmptyState" class="hidden px-6 py-10 text-center text-slate-500">ไม่พบข้อมูลรถราชการ</div>
  </div>
</section>

<div id="vehicleModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/50 px-4">
  <div class="w-full max-w-3xl rounded-2xl bg-white shadow-2xl">
    <div class="flex items-center justify-between border-b border-slate-200 px-5 py-4">
      <h3 id="vehicleModalTitle" class="text-lg font-bold text-slate-950">เพิ่มรถราชการ</h3>
      <button onclick="closeVehicleModal()" class="rounded-lg px-3 py-1 text-xl text-slate-500 hover:bg-slate-100">&times;</button>
    </div>

    <form id="vehicleForm" class="grid gap-4 p-5 sm:grid-cols-2">
      <input type="hidden" id="vehicle_id">

      <label class="block">
        <span class="mb-1 block text-sm font-semibold text-slate-700">ทะเบียนรถ</span>
        <input id="plate_no" class="vehicle-input" type="text">
      </label>

      <label class="block">
        <span class="mb-1 block text-sm font-semibold text-slate-700">ชื่อรถ</span>
        <input id="vehicle_name" class="vehicle-input" type="text">
      </label>

      <label class="block">
        <span class="mb-1 block text-sm font-semibold text-slate-700">ประเภทรถ</span>
        <input id="vehicle_type" class="vehicle-input" type="text">
      </label>

      <label class="block">
        <span class="mb-1 block text-sm font-semibold text-slate-700">ยี่ห้อ/รุ่น</span>
        <input id="brand_model" class="vehicle-input" type="text">
      </label>

      <label class="block">
        <span class="mb-1 block text-sm font-semibold text-slate-700">ประเภทเชื้อเพลิง</span>
        <input id="fuel_type" class="vehicle-input" type="text">
      </label>

      <label class="block">
        <span class="mb-1 block text-sm font-semibold text-slate-700">เลขไมล์ปัจจุบัน</span>
        <input id="current_mileage" class="vehicle-input" type="number" min="0" step="1">
      </label>

      <label class="block">
        <span class="mb-1 block text-sm font-semibold text-slate-700">สถานะ</span>
        <select id="status" class="vehicle-input">
          <option value="available">พร้อมใช้งาน</option>
          <option value="in_use">กำลังใช้งาน</option>
          <option value="repair">ซ่อมบำรุง</option>
          <option value="inactive">ไม่ใช้งาน</option>
        </select>
      </label>

      <label class="block sm:col-span-2">
        <span class="mb-1 block text-sm font-semibold text-slate-700">หมายเหตุ</span>
        <textarea id="remark" class="vehicle-input min-h-24" rows="3"></textarea>
      </label>

      <div class="flex justify-end gap-3 border-t border-slate-100 pt-4 sm:col-span-2">
        <button type="button" onclick="closeVehicleModal()" class="rounded-xl border border-slate-200 px-5 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50">ยกเลิก</button>
        <button type="submit" class="rounded-xl bg-sky-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-sky-700">บันทึก</button>
      </div>
    </form>
  </div>
</div>

<style>
  .vehicle-input {
    width: 100%;
    border-radius: 0.75rem;
    border: 1px solid rgb(226 232 240);
    background: rgb(248 250 252);
    padding: 0.7rem 0.9rem;
    outline: none;
  }

  .vehicle-input:focus {
    border-color: rgb(56 189 248);
    background: white;
    box-shadow: 0 0 0 4px rgb(224 242 254);
  }
</style>

<script>
  let vehicles = [];
  let vehicleLoadTimer = null;
  let vehiclePageInitialized = false;

  document.addEventListener('sphAuthReady', function () {
    initVehiclePage();
  });

  document.addEventListener('DOMContentLoaded', function () {
    setTimeout(initVehiclePage, 300);
    setTimeout(initVehiclePage, 1000);
  });

  function initVehiclePage() {
    if (vehiclePageInitialized || window.CURRENT_PAGE !== 'vehicles') {
      return;
    }

    const token = getVehicleToken();
    const form = document.getElementById('vehicleForm');

    if (!token) {
      document.getElementById('vehicleLoadInfo').textContent = 'Session หมดอายุ กรุณาเข้าสู่ระบบใหม่';
      return;
    }

    vehiclePageInitialized = true;

    if (form) {
      form.addEventListener('submit', submitVehicleForm);
    }

    bindVehicleTableActions();

    loadVehicles();
  }

  function bindVehicleTableActions() {
    const tableBody = document.getElementById('vehicleTableBody');

    if (!tableBody || tableBody.dataset.bound === 'true') {
      return;
    }

    tableBody.dataset.bound = 'true';
    tableBody.addEventListener('click', function (event) {
      const button = event.target.closest('[data-action="edit-vehicle"]');

      if (button) {
        openVehicleModal(button.dataset.vehicleId || '');
      }
    });
  }

  function loadVehicles() {
    const loadInfo = document.getElementById('vehicleLoadInfo');
    const token = getVehicleToken();

    if (!token) {
      loadInfo.textContent = 'Session หมดอายุ กรุณาเข้าสู่ระบบใหม่';
      return;
    }

    loadInfo.innerHTML = 'กำลังโหลดข้อมูลรถราชการ...';
    clearTimeout(vehicleLoadTimer);
    vehicleLoadTimer = setTimeout(function () {
      showLoading(false);
      loadInfo.innerHTML = 'โหลดข้อมูลนานผิดปกติ <button type="button" onclick="loadVehicles()" class="ml-2 rounded-lg bg-slate-900 px-3 py-1 text-xs font-semibold text-white">โหลดใหม่</button>';
    }, 12000);

    showLoading(true);
    google.script.run
      .withSuccessHandler(function (response) {
        clearTimeout(vehicleLoadTimer);
        showLoading(false);
        if (!response || !response.success) {
          loadInfo.textContent = response ? response.message : 'ไม่สามารถโหลดข้อมูลรถได้';
          showError(response ? response.message : 'ไม่สามารถโหลดข้อมูลรถได้');
          return;
        }
        vehicles = response.data || [];
        loadInfo.textContent = 'พบข้อมูลรถราชการ ' + vehicles.length + ' รายการ';
        if (vehicles.length === 0) {
          loadVehicleDebugInfo();
        }
        renderVehicleTable();
      })
      .withFailureHandler(function (error) {
        clearTimeout(vehicleLoadTimer);
        showLoading(false);
        loadInfo.textContent = error.message || 'ไม่สามารถโหลดข้อมูลรถได้';
        showError(error.message || 'ไม่สามารถโหลดข้อมูลรถได้');
      })
      .getVehicles(token);
  }

  function loadVehicleDebugInfo() {
    const token = getVehicleToken();

    if (!token) {
      return;
    }

    google.script.run
      .withSuccessHandler(function (response) {
        if (!response || !response.success || !response.data) return;
        const info = response.data;
        document.getElementById('vehicleLoadInfo').textContent =
          'พบข้อมูลรถราชการ 0 รายการ | Sheet: ' + (info.exists ? 'vehicles' : 'ไม่พบ') +
          ' | แถวทั้งหมด: ' + (info.lastRow || 0) +
          ' | ไฟล์: ' + (info.spreadsheetName || '-');
      })
      .withFailureHandler(function (error) {
        document.getElementById('vehicleLoadInfo').textContent = error.message || 'ตรวจสอบข้อมูลรถไม่สำเร็จ';
      })
      .getVehicleDebugInfo(token);
  }

  function renderVehicleTable() {
    const keyword = (document.getElementById('vehicleSearch').value || '').toLowerCase();
    const rows = vehicles.filter(function (vehicle) {
      return [
        vehicle.plate_no,
        vehicle.vehicle_name,
        vehicle.vehicle_type,
        vehicle.brand_model,
        getVehicleStatusLabel(vehicle.status)
      ].join(' ').toLowerCase().includes(keyword);
    });

    document.getElementById('vehicleEmptyState').classList.toggle('hidden', rows.length > 0);
    if (vehicles.length > 0 && rows.length === 0) {
      document.getElementById('vehicleEmptyState').textContent = 'ไม่พบข้อมูลที่ตรงกับคำค้นหา';
    } else {
      document.getElementById('vehicleEmptyState').textContent = 'ไม่พบข้อมูลรถราชการ';
    }
    document.getElementById('vehicleTableBody').innerHTML = rows.map(function (vehicle) {
      return '<tr class="hover:bg-slate-50">' +
        '<td class="px-4 py-3 text-sm font-semibold text-slate-900">' + escapeHtml(vehicle.plate_no) + '</td>' +
        '<td class="px-4 py-3 text-sm text-slate-700">' + escapeHtml(vehicle.vehicle_name) + '</td>' +
        '<td class="px-4 py-3 text-sm text-slate-600">' + escapeHtml(vehicle.vehicle_type) + '</td>' +
        '<td class="px-4 py-3 text-sm text-slate-600">' + escapeHtml(vehicle.brand_model) + '</td>' +
        '<td class="px-4 py-3 text-right text-sm text-slate-700">' + Number(vehicle.current_mileage || 0).toLocaleString('th-TH') + '</td>' +
        '<td class="px-4 py-3 text-sm">' + getVehicleStatusBadge(vehicle.status) + '</td>' +
        '<td class="px-4 py-3 text-right">' +
          '<button type="button" data-action="edit-vehicle" data-vehicle-id="' + escapeHtml(vehicle.vehicle_id) + '" class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white hover:bg-slate-700">แก้ไข</button>' +
        '</td>' +
      '</tr>';
    }).join('');
  }

  function openVehicleModal(vehicleId) {
    resetVehicleForm();
    if (vehicleId) {
      const vehicle = vehicles.find(function (item) { return item.vehicle_id === vehicleId; });
      if (vehicle) {
        document.getElementById('vehicleModalTitle').textContent = 'แก้ไขรถราชการ';
        Object.keys(vehicle).forEach(function (key) {
          const input = document.getElementById(key);
          if (input) input.value = vehicle[key] || '';
        });
      }
    } else {
      document.getElementById('vehicleModalTitle').textContent = 'เพิ่มรถราชการ';
      document.getElementById('status').value = 'available';
    }
    document.getElementById('vehicleModal').classList.remove('hidden');
    document.getElementById('vehicleModal').classList.add('flex');
  }

  function closeVehicleModal() {
    document.getElementById('vehicleModal').classList.add('hidden');
    document.getElementById('vehicleModal').classList.remove('flex');
  }

  function resetVehicleForm() {
    document.getElementById('vehicleForm').reset();
    document.getElementById('vehicle_id').value = '';
  }

  function submitVehicleForm(event) {
    event.preventDefault();

    const vehicleId = document.getElementById('vehicle_id').value;
    const payload = {
      plate_no: document.getElementById('plate_no').value.trim(),
      vehicle_name: document.getElementById('vehicle_name').value.trim(),
      vehicle_type: document.getElementById('vehicle_type').value.trim(),
      brand_model: document.getElementById('brand_model').value.trim(),
      fuel_type: document.getElementById('fuel_type').value.trim(),
      current_mileage: document.getElementById('current_mileage').value,
      status: document.getElementById('status').value,
      remark: document.getElementById('remark').value.trim()
    };

    if (!payload.plate_no || !payload.vehicle_name || payload.current_mileage === '') {
      showWarning('กรุณากรอกข้อมูลให้ครบถ้วน');
      return;
    }

    if (Number(payload.current_mileage) < 0 || isNaN(Number(payload.current_mileage))) {
      showWarning('เลขไมล์ปัจจุบันต้องเป็นตัวเลขและต้องไม่ติดลบ');
      return;
    }

    showLoading(true);
    const runner = google.script.run
      .withSuccessHandler(function (response) {
        showLoading(false);
        if (!response || !response.success) {
          showError(response ? response.message : 'บันทึกข้อมูลไม่สำเร็จ');
          return;
        }
        closeVehicleModal();
        Swal.fire({
          icon: 'success',
          title: 'บันทึกสำเร็จ',
          text: response.message,
          confirmButtonText: 'ตกลง'
        });
        loadVehicles();
      })
      .withFailureHandler(function (error) {
        showLoading(false);
        showError(error.message || 'บันทึกข้อมูลไม่สำเร็จ');
      });

    if (vehicleId) {
      runner.updateVehicle(vehicleId, payload, getVehicleToken());
    } else {
      runner.createVehicle(payload, getVehicleToken());
    }
  }

  function getVehicleToken() {
    return localStorage.getItem('sph_vehicle_log_token') || '';
  }

  function getVehicleStatusLabel(status) {
    const labels = {
      available: 'พร้อมใช้งาน',
      in_use: 'กำลังใช้งาน',
      repair: 'ซ่อมบำรุง',
      inactive: 'ไม่ใช้งาน'
    };
    return labels[status] || status || '-';
  }

  function getVehicleStatusBadge(status) {
    const styles = {
      available: 'bg-emerald-50 text-emerald-700 ring-emerald-100',
      in_use: 'bg-sky-50 text-sky-700 ring-sky-100',
      repair: 'bg-amber-50 text-amber-700 ring-amber-100',
      inactive: 'bg-slate-100 text-slate-600 ring-slate-200'
    };
    return '<span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold ring-1 ' + (styles[status] || styles.inactive) + '">' + getVehicleStatusLabel(status) + '</span>';
  }

  function showError(message) {
    Swal.fire({ icon: 'error', title: 'เกิดข้อผิดพลาด', text: message, confirmButtonText: 'ตกลง' });
  }

  function showWarning(message) {
    Swal.fire({ icon: 'warning', title: 'ข้อมูลไม่ครบ', text: message, confirmButtonText: 'ตกลง' });
  }

  function escapeHtml(value) {
    return String(value || '').replace(/[&<>"']/g, function (char) {
      return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' })[char];
    });
  }
</script>
