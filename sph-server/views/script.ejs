<script>
  const TOKEN_KEY = 'sph_vehicle_log_token';
  const USER_KEY = 'sph_vehicle_log_user';

  // --- Node.js Backend Emulator for google.script.run ---
  window.google = window.google || {};
  Object.defineProperty(window.google, 'script', {
    value: {
      get run() {
        const runner = {
          _success: null,
          _failure: null,
          withSuccessHandler: function(cb) { this._success = cb; return this; },
          withFailureHandler: function(cb) { this._failure = cb; return this; }
        };
        
        return new Proxy(runner, {
          get: function(target, prop) {
            if (prop in target) return target[prop];
            
            return function(...args) {
              console.log('RPC Call:', prop, args);
              fetch('/api/rpc/' + prop, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify(args)
              })
              .then(res => {
                if (!res.ok) throw new Error(`HTTP Error ${res.status}`);
                return res.json();
              })
              .then(data => {
                console.log('RPC Response:', prop, data);
                if (data.error && target._failure) target._failure(new Error(data.error));
                else if (target._success) target._success(data.result);
              })
              .catch(err => {
                console.error('RPC Error:', prop, err);
                if (target._failure) target._failure(err);
                else alert('RPC Error: ' + err.message);
              });
            };
          }
        });
      }
    }
  });
  // ----------------------------------------------------

  document.addEventListener('DOMContentLoaded', function () {
    hydrateInitialAuth();

    const user = getStoredUser();
    const token = localStorage.getItem(TOKEN_KEY);

    if (!token || !user) {
      redirectToLogin();
      return;
    }

    renderUser(user);
    renderMenu(user);
    guardPage(user);
    window.SPH_AUTH_READY = true;
    window.SPH_AUTH_CONTEXT = {
      user: user,
      token: token
    };
    document.dispatchEvent(new CustomEvent('sphAuthReady', {
      detail: {
        user: user,
        token: token
      }
    }));
  });

  function hydrateInitialAuth() {
    if (!window.INITIAL_AUTH || !window.INITIAL_AUTH.token || !window.INITIAL_AUTH.user) {
      return;
    }

    localStorage.setItem(TOKEN_KEY, window.INITIAL_AUTH.token);
    localStorage.setItem(USER_KEY, JSON.stringify(window.INITIAL_AUTH.user));
  }

  function getStoredUser() {
    try {
      return JSON.parse(localStorage.getItem(USER_KEY) || 'null');
    } catch (error) {
      return null;
    }
  }

  function renderUser(user) {
    const fullName = user.full_name || '-';
    document.getElementById('topbarFullName').textContent = fullName;
    
    let roleText = 'ผู้ใช้งาน';
    const role = (user.role || '').toLowerCase();
    if (role === 'admin') {
      roleText = 'ผู้ดูแลระบบ (Admin)';
    } else if (role === 'manager') {
      roleText = 'หัวหน้าแผนก (Manager)';
    } else if (role === 'driver_head') {
      roleText = 'หัวหน้าพนักงานขับรถ (Driver Head)';
    } else if (role === 'driver') {
      roleText = 'พนักงานขับรถ (Driver)';
    }
    document.getElementById('topbarRole').textContent = roleText;

    // แสดงที่ footer
    const footerNameEl = document.getElementById('footerFullName');
    const footerRoleEl = document.getElementById('footerRole');
    if (footerNameEl) footerNameEl.textContent = fullName;
    if (footerRoleEl) footerRoleEl.textContent = roleText;
  }

  function renderMenu(user) {
    const userRole = (user.role || 'user').toLowerCase();
    const customAllowed = user.allowed_pages && user.allowed_pages.trim() ? user.allowed_pages.split(',') : null;
    
    const allMenus = [
      { page: 'dashboard', label: 'Dashboard', icon: '📊', roles: ['admin', 'manager', 'driver_head'] },
      { page: 'usage-form', label: 'ขอใช้รถ', icon: '📝', roles: ['admin', 'manager', 'driver_head', 'driver', 'user'] },
      { page: 'usage-list', label: 'รายการใช้รถ', icon: '📋', roles: ['admin', 'manager', 'driver_head', 'driver', 'user'] },
      { type: 'section', label: 'ข้อมูลหลัก', roles: ['admin'] },
      { page: 'master-data', label: 'จัดการข้อมูลหลัก', icon: '🗂️', roles: ['admin'] },
      { type: 'section', label: 'ผู้ดูแลระบบ', roles: ['admin', 'manager'] },
      { page: 'users', label: 'จัดการผู้ใช้งาน', icon: '🔐', roles: ['admin', 'manager'] },
      { page: 'reports', label: 'รายงาน', icon: '📈', roles: ['admin', 'manager', 'driver_head'] },
      { page: 'audit-logs', label: 'ประวัติระบบ', icon: '🧾', roles: ['admin'] }
    ];

    const menus = allMenus.filter(function (m) {
      if (m.type === 'section') return true;
      if (customAllowed) {
        return customAllowed.indexOf(m.page) !== -1;
      }
      return !m.roles || m.roles.indexOf(userRole) !== -1;
    });

    // Clean up empty sections
    const cleanedMenus = [];
    for (let i = 0; i < menus.length; i++) {
      const m = menus[i];
      if (m.type === 'section') {
        let hasPage = false;
        for (let j = i + 1; j < menus.length; j++) {
          if (menus[j].type === 'section') break;
          if (menus[j].page) {
            hasPage = true;
            break;
          }
        }
        if (hasPage) {
          cleanedMenus.push(m);
        }
      } else {
        cleanedMenus.push(m);
      }
    }

    const sidebarMenu = document.getElementById('sidebarMenu');

    sidebarMenu.innerHTML = cleanedMenus.map(function (menu) {
      if (menu.type === 'section') {
        return '<div class="px-3 pt-4 pb-1 text-xs font-bold uppercase tracking-wide text-slate-400">' + menu.label + '</div>';
      }

      let label = menu.label;
      if (menu.page === 'usage-list') {
        if (userRole === 'manager') label = 'รายการใช้รถในฝ่าย';
        else if (userRole === 'driver') label = 'ตารางงานขับรถของฉัน';
        else if (userRole === 'user') label = 'ประวัติการบันทึกของฉัน';
        else label = 'รายการใช้รถทั้งหมด';
      }

      const activeClass = menu.page === window.CURRENT_PAGE ? ' active' : '';
      return '<a class="menu-link' + activeClass + '" href="' + getPageUrl(menu.page) + '">' +
        '<span class="text-lg">' + menu.icon + '</span>' +
        '<span>' + label + '</span>' +
        '</a>';
    }).join('');
  }

  function guardPage(user) {
    const allowedPagesMap = {
      admin: ['dashboard', 'usage-form', 'usage-list', 'master-data', 'users', 'reports', 'audit-logs'],
      manager: ['dashboard', 'usage-form', 'usage-list', 'users', 'reports'],
      driver_head: ['dashboard', 'usage-form', 'usage-list', 'reports'],
      driver: ['usage-form', 'usage-list'],
      user: ['usage-form', 'usage-list']
    };

    const userRole = (user.role || 'user').toLowerCase();
    let userAllowed = allowedPagesMap[userRole] || ['usage-form', 'usage-list'];

    if (user.allowed_pages && user.allowed_pages.trim()) {
      userAllowed = user.allowed_pages.split(',');
    }

    if (userAllowed.indexOf(window.CURRENT_PAGE) === -1) {
      Swal.fire({
        icon: 'warning',
        title: 'ไม่มีสิทธิ์',
        text: 'คุณไม่มีสิทธิ์เข้าถึงเมนูนี้',
        confirmButtonText: 'ตกลง'
      }).then(function () {
        navigateTop(getPageUrl('usage-form'));
      });
    }
  }

  function handleLogout() {
    // Fire RPC to log audit trail (cookie-based auth, no token arg needed)
    google.script.run.logout();
    clearLocalSession();
    navigateTop('/logout');
  }

  function clearLocalSession() {
    localStorage.removeItem(TOKEN_KEY);
    localStorage.removeItem(USER_KEY);
  }

  function redirectToLogin() {
    navigateTop(getPageUrl('login'));
  }

  function getPageUrl(page) {
    return '/' + page;
  }

  function navigateTop(url) {
    const link = document.createElement('a');
    link.href = url;
    link.target = '_top';
    link.rel = 'noopener';
    document.body.appendChild(link);
    link.click();
    link.remove();
  }

  function toggleSidebar(isOpen) {
    const sidebar = document.getElementById('sidebar');
    const backdrop = document.getElementById('sidebarBackdrop');

    if (isOpen) {
      sidebar.classList.remove('-translate-x-full');
      backdrop.classList.remove('hidden');
    } else {
      sidebar.classList.add('-translate-x-full');
      backdrop.classList.add('hidden');
    }
  }

  function showLoading(isVisible) {
    const overlay = document.getElementById('loadingOverlay');
    overlay.classList.toggle('hidden', !isVisible);
    overlay.classList.toggle('flex', isVisible);
  }

  function formatThaiDate(value) {
    const text = String(value || '').trim();
    const isoMatch = text.match(/^(\d{4})-(\d{1,2})-(\d{1,2})/);
    const thaiMatch = text.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})/);

    if (isoMatch) {
      return isoMatch[3].padStart(2, '0') + '/' + isoMatch[2].padStart(2, '0') + '/' + (Number(isoMatch[1]) + 543);
    }

    if (thaiMatch) {
      const year = Number(thaiMatch[3]);
      return thaiMatch[1].padStart(2, '0') + '/' + thaiMatch[2].padStart(2, '0') + '/' + (year > 2400 ? year : year + 543);
    }

    return text;
  }

  function formatTime(value) {
    const text = String(value || '').trim();
    const match = text.match(/(\d{1,2}):(\d{2})/);

    if (!match) {
      return '';
    }

    return String(match[1]).padStart(2, '0') + ':' + match[2];
  }

  function formatTimeRange(startTime, endTime) {
    return formatTime(startTime) + '-' + (formatTime(endTime) || 'ยังไม่กลับ');
  }

  function toIsoDate(date) {
    return date.toISOString().slice(0, 10);
  }

  function formatNumber(value) {
    return Number(value || 0).toLocaleString('th-TH');
  }

  function runServerFunction(methodName, args, onSuccess, onFailure) {
    var runner = google.script.run
      .withSuccessHandler(function (response) {
        if (onSuccess) {
          onSuccess(response);
        }
      })
      .withFailureHandler(function (error) {
        showLoading(false);
        if (onFailure) {
          onFailure(error);
          return;
        }
        Swal.fire({
          icon: 'error',
          title: 'ดำเนินการไม่สำเร็จ',
          text: error && error.message ? error.message : 'ไม่สามารถเชื่อมต่อระบบได้',
          confirmButtonText: 'ตกลง'
        });
      });

    return runner[methodName].apply(runner, args || []);
  }
</script>
